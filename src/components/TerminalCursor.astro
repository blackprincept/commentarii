<span class="cursor">&nbsp;</span>

<style>
    .cursor {
        display: inline-block;
        width: 0.6em;
        background: var(--fg);
        animation: blink 1s step-end infinite;
    }

    @keyframes blink {
        0%,
        49% {
            opacity: 1;
        }
        50%,
        100% {
            opacity: 0;
        }
    }
</style>
