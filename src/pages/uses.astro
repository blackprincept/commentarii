---
import BaseLayout from "../layouts/BaseLayout.astro";
import { uses } from "../data/uses.ts";
import TerminalLine from "../components/TerminalLine.astro";
import TerminalCursor from "../components/TerminalCursor.astro";
---

<BaseLayout>
    <div class="container terminal">
        <a href="/">
            <TerminalLine>
                <span class="command">cd</span> ..<TerminalCursor />
            </TerminalLine>
        </a>

        <TerminalLine>ls -l ./uses</TerminalLine>

        {
            uses.map((tool) => (
                <article class="terminal">
                    <p>{tool.name}</p>
                    {tool.specs && (
                        <dl class="terminal">
                            {tool.specs.map((spec) => (
                                <div class="spec-row">
                                    <dt class="spec-label">{spec.label}</dt>
                                    <dd class="spec-value">{spec.value}</dd>
                                </div>
                            ))}
                        </dl>
                    )}
                </article>
            ))
        }
    </div>
</BaseLayout>

<style>
    .spec-row {
        display: grid;
        grid-template-columns: 12rem 1fr;
        gap: var(--line-gap);
    }

    .spec-label {
        color: var(--fg-3);
        text-transform: uppercase;
    }

    .spec-value {
        color: var(--fg);
    }

    @media (max-width: 32rem) {
        .spec-row {
            grid-template-columns: 1fr;
        }
    }
</style>
